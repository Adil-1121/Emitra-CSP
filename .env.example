# ── G.N E-Mitra Environment Variables ────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git.

# ── Backend API ───────────────────────────────────────────────────────────────
VITE_API_BASE_URL=https://your-backend.onrender.com/

# ── Mistral AI (Development only) ────────────────────────────────────────────
# Get your free API key from: https://console.mistral.ai/
# ⚠️  For development/testing only. Move to backend for production.
VITE_MISTRAL_API_KEY=your_mistral_api_key_here

# ── Future: Backend AI proxy (Production) ────────────────────────────────────
# When you move AI calls to your backend, set this and change
# AI_CONFIG.provider = 'backend' in src/config/ai.js
# VITE_AI_BACKEND_URL=https://your-backend.com/api/chat
